            "example": "Mensagem de erro"
          }
        }
      },
      "usuario": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 999
          },
          "nome": {
            "type": "string",
            "example": "Fulano de Tal"
          },
          "email": {
            "type": "string",
            "example": "fulano@unoeste.br"
          },
          "senha": {
            "type": "string",
            "example": "123abc"
          },
