              }
            }
          }
        }
      },
      "imovel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 999,
            "required": false
          },
          "descricao": {
            "type": "string",
            "required": true
          },
          "endereco": {
            "type": "string",
            "required": true
          },
